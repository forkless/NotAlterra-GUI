<Window
    x:Class="NotAlterra.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NotAlterra"
    Width="1200"
    Height="800"
    Background="{StaticResource AppBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- ═══ Main Navigation Area ═══ -->
        <NavigationView
            x:Name="MainNav"
            Grid.Row="0"
            PaneDisplayMode="Compact"
            CompactPaneLength="48"
            AlwaysShowHeader="False"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
            SelectionChanged="OnNavSelectionChanged"
            Background="{StaticResource AppBackground}"
            PaneBackground="#161B22"
            ContentOverlayColor="#0D1117">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavDashboard" Tag="dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavSaves" Tag="saves" Content="Saves">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE1A2;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavBackups" Tag="backups" Content="Backups">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE895;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavConfig" Tag="config" Content="Config">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.ContentOverlay>
                <Grid x:Name="PageRoot" Margin="0,0,0,0">

                    <!-- ── Dashboard Page ── -->
                    <ScrollViewer x:Name="DashboardPage" Visibility="Visible">
                        <StackPanel Margin="32,24,32,24" Spacing="24">

                            <!-- Status Report Header -->
                            <TextBlock
                                Text="Status Report"
                                FontSize="32"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource AppForeground}"
                                Margin="0,0,0,0"/>

                            <!-- Stat Cards Row -->
                            <StackPanel Orientation="Horizontal" Spacing="16">

                                <!-- Card: Saves -->
                                <Border
                                    Width="220" Height="96"
                                    Background="{StaticResource CardBackground}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0" Spacing="4">
                                        <TextBlock Text="Total Saves" FontSize="12"
                                            Foreground="{StaticResource MutedForeground}"/>
                                        <TextBlock x:Name="StatSaves" Text="12" FontSize="28"
                                            FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card: Backups -->
                                <Border
                                    Width="220" Height="96"
                                    Background="{StaticResource CardBackground}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0" Spacing="4">
                                        <TextBlock Text="Backups" FontSize="12"
                                            Foreground="{StaticResource MutedForeground}"/>
                                        <TextBlock x:Name="StatBackups" Text="8" FontSize="28"
                                            FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card: Playtime -->
                                <Border
                                    Width="220" Height="96"
                                    Background="{StaticResource CardBackground}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0" Spacing="4">
                                        <TextBlock Text="Playtime" FontSize="12"
                                            Foreground="{StaticResource MutedForeground}"/>
                                        <TextBlock x:Name="StatPlaytime" Text="142h" FontSize="28"
                                            FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Card: Last Run -->
                                <Border
                                    Width="220" Height="96"
                                    Background="{StaticResource CardBackground}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0" Spacing="4">
                                        <TextBlock Text="Last Run" FontSize="12"
                                            Foreground="{StaticResource MutedForeground}"/>
                                        <TextBlock x:Name="StatLastRun" Text="Today" FontSize="28"
                                            FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Save Slots Table -->
                            <Border
                                Background="{StaticResource CardBackground}"
                                CornerRadius="12"
                                BorderBrush="#2D333B"
                                BorderThickness="1"
                                Padding="0">
                                <Grid Margin="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="36"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Header Row -->
                                    <Border Grid.Row="0" Grid.ColumnSpan="5"
                                        Background="#21262D" BorderBrush="#2D333B"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="#" FontSize="11"
                                                Foreground="{StaticResource MutedForeground}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Save Name" FontSize="11"
                                                Foreground="{StaticResource MutedForeground}"
                                                VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            <TextBlock Grid.Column="2" Text="Last Modified" FontSize="11"
                                                Foreground="{StaticResource MutedForeground}"
                                                VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Playtime" FontSize="11"
                                                Foreground="{StaticResource MutedForeground}"
                                                VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="File Size" FontSize="11"
                                                Foreground="{StaticResource MutedForeground}"
                                                VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Row 1 -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="1" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Survival - Day 47" FontSize="13"
                                        Foreground="{StaticResource AppForeground}"
                                        VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="2025-03-15 22:34" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="34h 12m" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="8.2 MB" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>

                                    <!-- Row 2 -->
                                    <Border Grid.Row="2" Grid.ColumnSpan="5"
                                        BorderBrush="#2D333B" BorderThickness="0,0,0,1"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="2" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Creative Base Alpha" FontSize="13"
                                        Foreground="{StaticResource AppForeground}"
                                        VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="2025-03-10 14:12" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="12h 45m" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="4" Text="4.7 MB" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>

                                    <!-- Row 3 -->
                                    <Border Grid.Row="3" Grid.ColumnSpan="5"
                                        BorderBrush="#2D333B" BorderThickness="0,0,0,1"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="3" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Hardcore Run #4" FontSize="13"
                                        Foreground="{StaticResource AppForeground}"
                                        VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="2025-02-28 09:45" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="6h 30m" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="4" Text="3.1 MB" FontSize="12"
                                        Foreground="{StaticResource MutedForeground}"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- "Nothing but void" note -->
                            <Border
                                Background="{StaticResource CardBackground}"
                                CornerRadius="12"
                                BorderBrush="#2D333B"
                                BorderThickness="1"
                                Padding="20,16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Nothing but void..." FontSize="18"
                                        FontWeight="SemiBold" Foreground="{StaticResource MutedForeground}"
                                        Opacity="0.6"/>
                                    <TextBlock Text="The deep waters hold many secrets. Select a save to begin exploring its depths."
                                        FontSize="13" Foreground="{StaticResource MutedForeground}"
                                        TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Saves Page ── -->
                    <ScrollViewer x:Name="SavesPage" Visibility="Collapsed">
                        <StackPanel Margin="32,24,32,24" Spacing="16">
                            <TextBlock Text="Save Files" FontSize="32"
                                FontWeight="SemiBold" Foreground="{StaticResource AppForeground}"/>
                            <TextBlock Text="Browse and manage your Subnautica save files."
                                FontSize="14" Foreground="{StaticResource MutedForeground}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Backups Page ── -->
                    <ScrollViewer x:Name="BackupsPage" Visibility="Collapsed">
                        <StackPanel Margin="32,24,32,24" Spacing="16">
                            <TextBlock Text="Backups" FontSize="32"
                                FontWeight="SemiBold" Foreground="{StaticResource AppForeground}"/>
                            <TextBlock Text="Automatic and manual backup management."
                                FontSize="14" Foreground="{StaticResource MutedForeground}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Config Page ── -->
                    <ScrollViewer x:Name="ConfigPage" Visibility="Collapsed">
                        <StackPanel Margin="32,24,32,24" Spacing="16">
                            <TextBlock Text="Configuration" FontSize="32"
                                FontWeight="SemiBold" Foreground="{StaticResource AppForeground}"/>
                            <TextBlock Text="Application settings and preferences."
                                FontSize="14" Foreground="{StaticResource MutedForeground}"/>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </NavigationView.ContentOverlay>
        </NavigationView>

        <!-- ═══ Footer (Sonar Bar) ═══ -->
        <Border
            Grid.Row="1"
            Height="48"
            Background="{StaticResource CardBackground}"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="0,1,0,0">
            <Grid Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sonar sweep bar -->
                <Border
                    Grid.Column="0"
                    Height="4"
                    CornerRadius="2"
                    Background="#2D333B"
                    VerticalAlignment="Center">
                    <Border
                        x:Name="SonarSweep"
                        Width="60"
                        Height="4"
                        CornerRadius="2"
                        Background="{StaticResource SonarAccent}"
                        HorizontalAlignment="Left"
                        Opacity="0.7"/>
                </Border>

                <!-- Depth / Status text -->
                <TextBlock
                    Grid.Column="2"
                    Text="Depth: 0m — Scanning..."
                    FontSize="12"
                    Foreground="{StaticResource MutedForeground}"
                    VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
