<Application
    x:Class="NotAlterra.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Deep Current Theme Brushes -->
            <SolidColorBrush x:Key="AppBackground" Color="#0D1117"/>
            <SolidColorBrush x:Key="CardBackground" Color="#161B22"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#00BFA5"/>
            <SolidColorBrush x:Key="AppForeground" Color="#E6EDF3"/>
            <SolidColorBrush x:Key="MutedForeground" Color="#8B949E"/>
            <SolidColorBrush x:Key="SonarAccent" Color="#00BFA5"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
