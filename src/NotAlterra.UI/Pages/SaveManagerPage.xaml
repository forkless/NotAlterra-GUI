<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NotAlterra_UI.Pages.SaveManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NotAlterra_UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Save Manager" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Manage your Subnautica 2 save files" />

            <Button x:Name="SaveSlotsBtn" Click="OnSaveSlots" HorizontalAlignment="Stretch" Height="80" CornerRadius="8" Margin="0,8,0,0" Background="{ThemeResource CardBackgroundFillColorDefault}">
                <StackPanel VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="Save Slots" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Browse, inspect and recover save files" Opacity="0.6" FontSize="13"/>
                </StackPanel>
            </Button>

            <Button x:Name="BackupsBtn" Click="OnBackups" HorizontalAlignment="Stretch" Height="80" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}">
                <StackPanel VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="Backups" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Create and restore full save archives" Opacity="0.6" FontSize="13"/>
                </StackPanel>
            </Button>

            <Button x:Name="IniConfigBtn" Click="OnIniConfig" HorizontalAlignment="Stretch" Height="80" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}">
                <StackPanel VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="INI Config" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Manage UE5 configuration files" Opacity="0.6" FontSize="13"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>
