<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="NotAlterra_UI.Pages.MetadataHoverCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="CardBorder" CornerRadius="10"
            Background="{ThemeResource SystemChromeLowColor}"
            Padding="16" MaxWidth="460">
        <StackPanel Spacing="4">

            <!-- Header: DisplayName -->
            <TextBlock x:Name="DisplayNameText" FontSize="18" FontWeight="Bold"
                       Foreground="#FFe85d04" TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,4"/>
            <Rectangle Height="1" Fill="#333" Margin="0,0,0,6"/>

            <!-- Section 1: identity -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Slot:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="SlotText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Game Mode:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="GameModeText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Level:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="LevelText" FontSize="13" TextTrimming="CharacterEllipsis"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mode:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="ModeText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Branch:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="BranchText" FontSize="13" TextTrimming="CharacterEllipsis"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Build:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="BuildText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Playtime:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="PlaytimeText" FontSize="13"/>
            </Grid>

            <Rectangle Height="1" Fill="#333" Margin="0,4,0,6"/>

            <!-- Section 2: save version info -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Save Count:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="SaveCountText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Save Ver:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="SaveVerText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Data Ver:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="DataVerText" FontSize="13"/>
            </Grid>

            <Rectangle Height="1" Fill="#333" Margin="0,4,0,6"/>

            <!-- Section 3: file info -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="File:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="FileText" FontSize="13" TextTrimming="CharacterEllipsis"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Size:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="SizeText" FontSize="13"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Modified:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="ModifiedText" FontSize="13"/>
            </Grid>

            <Rectangle Height="1" Fill="#333" Margin="0,4,0,6"/>

            <!-- Section 4: corruption -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Corruption:" Opacity="0.6" FontSize="13"/>
                <TextBlock Grid.Column="1" x:Name="CorruptionText" FontSize="13" TextWrapping="Wrap"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
