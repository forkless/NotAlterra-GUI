<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NotAlterra_UI.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NotAlterra_UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="12">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="NotAlterra" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Subnautica 2 Save Manager" />

            <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,4">
                Version <Run Text="{x:Bind AppVersion}"/> · <Run Text="{x:Bind BuildInfo}"/>
            </TextBlock>

            <!-- Stats card -->
            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Technical Specifications" FontSize="18" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="160, *" RowSpacing="10" ColumnSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Parsing engine" Opacity="0.6"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ParsingEngine}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Text="Metadata properties" Opacity="0.6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind SupportedProperties}"/>

                        <TextBlock Grid.Row="2" Text="Test corpus" Opacity="0.6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"><Run Text="{x:Bind TestFiles}"/> real .sav files</TextBlock>

                        <TextBlock Grid.Row="3" Text="Test suite" Opacity="0.6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind TestCoverage}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="4" Text="Fuzz testing" Opacity="0.6"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind FuzzStats}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="5" Text="Dependencies" Opacity="0.6"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind Dependencies}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="6" Text="Binary" Opacity="0.6"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind BinarySize}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="7" Text="Bus factor" Opacity="0.6"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="1 (it's just me. forkless. hi.)" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="8" Text="Total downloads" Opacity="0.6"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="3 ...including family" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="9" Text="Splash screen" Opacity="0.6"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" TextWrapping="Wrap">3 seconds of pure vanity. The app loads in ~300ms but I love seeing my homemade splash. So tough luck!</TextBlock>

                        <TextBlock Grid.Row="10" Text="Game Guard" Opacity="0.6"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" TextWrapping="Wrap">Checks if Subnautica 2 is running before destructive operations. Has saved exactly zero saves so far but it makes me look professional.</TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="About 42MB" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                        No it is not the 3.7MB 40-second loop.webm. It is prerequisites are downloaded and downloaded separately if needed. Think of it as the Windows App Tax. You pay it once and forget about it. If you dont like OS overhead you know where the Linux ISO is. Or TempleOS if you hate yourself.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">The installer is 19MB. The real weight (~160MB) is Microsoft's .NET + WinAppSDK runtimes — you already have them if you built this from source. NotAlterra itself is a featherweight. The taxman is Microsoft, not us. But hey, at least we prompt you to download them instead of silently shipping a 200MB installer. You are welcome.</TextBlock>
                </StackPanel>
            </Border>



            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Post Early Access Planned Features" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                        font size slider for sidebar text (because someone asked)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                        font color thingy
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                        probably more stuff i forgot
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                        maybe a dark mode toggle for the dark mode that is already on (peak UX)
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Copyright &amp; Attribution" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.8">
                    This is an unofficial fan-made utility and is not affiliated with or endorsed by KRAFTON or Unknown Worlds Entertainment.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6">
                    KRAFTON® is a registered trademark of KRAFTON, Inc., and Unknown Worlds Entertainment™ is a trademark of Unknown Worlds Entertainment, Inc.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.4">
                    Unreal® is a trademark or registered trademark of Epic Games, Inc. in the United States of America and elsewhere.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.4">
                    Unreal Engine, Copyright 1998-2026, Epic Games, Inc. All rights reserved.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                    This app will not:
                    ▪ connect to the internet. It contains zero networking code.
                    ▪ send telemetry, analytics, or crash reports of any kind.
                    ▪ enable the Windows App SDK opt-in telemetry feature.
                    ▪ store anything beyond timestamps.
                    ▪ store any data beyond the HKCU\Software\NotAlterra registry keys.
                    This tool runs entirely offline.
                    </TextBlock>
                    <StackPanel Spacing="4" Margin="0,4,0,0">
                    <TextBlock Text="Sidebar video by Pachon Curubeto" Opacity="0.5"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.5">
                    <FontIcon Glyph="&#xF16D;" FontFamily="../Assets/FontAwesomeBrands.ttf#Font Awesome 6 Brands" FontSize="14" VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <HyperlinkButton Content="Pachon in Motion" NavigateUri="https://instagram.com/Pachon.In.Motion" FontSize="14" Padding="0" Opacity="0.9"/>
                    <TextBlock Text="· Argentina"/>
                    </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Opacity="0.4">
                    NotAlterra © 2026 forkless.com - released under the MIT License
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Disclaimer" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.5">
                        You already accepted it during setup. If you want to read the wall of text again, you do you. Go read the MIT License, go bash a EULA you do not like. I am not your mom, read what you click.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
