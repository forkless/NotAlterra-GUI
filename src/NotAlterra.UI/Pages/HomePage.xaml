<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NotAlterra_UI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NotAlterra_UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="NotAlterra" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Subnautica 2 Save Manager" />
            <TextBlock Opacity="0.6" Text="Not affiliated with Unknown Worlds Entertainment or KRAFTON." />

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                <Button x:Name="ScanButton" Click="OnScanSaves" Content="Scan Saves" />
                <Button x:Name="ParseButton" Click="OnParseSave" Content="Parse First Save" />
                <Button x:Name="BackupButton" Click="OnTestBackup" Content="Test Backup" />
            </StackPanel>

            <!-- Save path display -->
            <TextBlock x:Name="SavePathText" Style="{StaticResource BodyTextBlockStyle}" />

            <!-- Metadata display -->
            <ListView x:Name="MetaList" MinHeight="200" MaxHeight="400" Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Key}" />
                            <TextBlock Grid.Column="1" Text="{Binding Value}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Backup result display -->
            <TextBlock x:Name="ResultText" Style="{StaticResource BodyTextBlockStyle}" />
        </StackPanel>
    </ScrollViewer>
</Page>
