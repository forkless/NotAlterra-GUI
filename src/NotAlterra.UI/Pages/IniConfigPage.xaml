<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NotAlterra_UI.Pages.IniConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NotAlterra_UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="24,24,24,0" Margin="0,0,0,16" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="&#xE97A;" FontFamily="Segoe MDL2 Assets" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" RenderTransformOrigin="0.5,0" Tapped="OnGoBack"><TextBlock.RenderTransform><ScaleTransform ScaleY="-1"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="INI Management" VerticalAlignment="Center"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="CreateBtn" Click="OnCreateBackup" Height="60" FontWeight="SemiBold" FontSize="16">
                    <StackPanel VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="Create INI Backup" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Archive UE5 configuration files" FontSize="13" Opacity="0.5" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" HorizontalAlignment="Right" x:Name="DeleteBtn" Click="OnDeleteIni" Height="60" FontWeight="SemiBold" FontSize="16">
                    <StackPanel VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="Delete INI Files" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Remove all UE5 config files" FontSize="13" Opacity="0.5" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="24,0,24,24" Spacing="12">
                <TextBlock x:Name="StatusText" Text="Loading..." Opacity="0.6" Visibility="Collapsed"/>
                <ItemsRepeater x:Name="BackupList">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#FFe85d04" Width="4" HorizontalAlignment="Left" Margin="0,4,0,4"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="16,16,0,16">
                                        <TextBlock Text="INI Config backup" FontSize="16" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="14" Opacity="0.6"/>
                                            <TextBlock Text="{Binding DateDisplay}" FontSize="14" Opacity="0.6"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8" Margin="0,0,16,0">
                                        <Button Content="Restore" Tag="{Binding Path}" Click="OnRestoreArchive" FontSize="13" Padding="14,8"/>
                                        <Button Content="Delete" Tag="{Binding Path}" Click="OnDeleteArchive" FontSize="13" Padding="14,8" Style="{StaticResource AccentButtonStyle}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
