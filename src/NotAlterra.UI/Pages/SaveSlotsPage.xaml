<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NotAlterra_UI.Pages.SaveSlotsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NotAlterra_UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="24,24,24,0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Save Slots"/>
            <TextBlock x:Name="StatusText" Text="Scanning..." Opacity="0.6" Margin="0,4,0,12"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <ItemsRepeater x:Name="SlotList" Margin="24,0,24,24">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" CornerRadius="10" Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="20">
                            <StackPanel Spacing="8">
                                <!-- Main slot row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="8" Background="#1A66FFFF" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Number}" FontSize="24" FontWeight="Bold" Foreground="#FF66FFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{Binding NameDisplay}" FontSize="16" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding PlaytimeDisplay}" FontSize="13" Foreground="#FF66FFFF"/>
                                            <TextBlock Text="{Binding ModeDisplay}" FontSize="13" Opacity="0.6"/>
                                            <TextBlock Text="{Binding GameModeDisplay}" FontSize="13" Opacity="0.6"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="12" Opacity="0.5"/>
                                            <TextBlock Text="{Binding ModifiedDisplay}" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                        <Border CornerRadius="4" Background="#1A66FFFF" Padding="8,3">
                                            <TextBlock Text="{Binding SavesCountDisplay}" FontSize="11" Foreground="#FF66FFFF"/>
                                        </Border>
                                        <Border CornerRadius="4" Background="#1AFFFFFF" Padding="8,3" Opacity="0.4">
                                            <TextBlock Text="{Binding BuildDisplay}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <!-- Backup sub-list -->
                                <ItemsRepeater ItemsSource="{Binding Backups}" Margin="32,0,0,0">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4,0,0" Opacity="0.7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Opacity="0.5"/>
                                                        <TextBlock Text="{Binding ModifiedDisplay}" FontSize="11" Opacity="0.5"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
