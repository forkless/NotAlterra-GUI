<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NotAlterra_UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NotAlterra_UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="NotAlterra"
    mc:Ignorable="d">
    <Window.SystemBackdrop><MicaBackdrop/></Window.SystemBackdrop>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar" Title="NotAlterra" BackRequested="TitleBar_BackRequested" IsBackButtonVisible="False" IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource><ImageIconSource ImageSource="Assets/AppIcon.ico"/></TitleBar.IconSource>
        </TitleBar>
        <Grid x:Name="MainGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Custom sidebar -->
            <Grid x:Name="Sidebar" Grid.Column="0">
                <Grid.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Video background fills entire sidebar -->
                <MediaPlayerElement x:Name="SidebarVideo" Grid.RowSpan="5" Stretch="UniformToFill" AreTransportControlsEnabled="false"/>
                <!-- Dark overlay behind Home + About (rows 1-2) -->
                <Rectangle Grid.Row="1" Grid.RowSpan="2" Fill="#CC151A22"/>
                <!-- Dark overlay behind Settings (row 4) -->
                <Rectangle Grid.Row="4" Fill="#CC151A22"/>
                <!-- Home -->
                <Button Grid.Row="1" x:Name="HomeBtn" Tag="home" Background="Transparent" Foreground="White" FontWeight="Bold" BorderThickness="0" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" Height="44" CornerRadius="0" Click="NavBtn_Click">
                    <Grid><Rectangle x:Name="HomeInd" Fill="#FF66FFFF" Width="3" HorizontalAlignment="Left" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE80F;" FontWeight="Bold" Foreground="White" FontSize="14" Margin="12,0,8,0"/>
                        <TextBlock Text="Home" VerticalAlignment="Center"/>
                    </StackPanel></Grid>
                </Button>
                <!-- About -->
                <Button Grid.Row="2" x:Name="AboutBtn" Tag="about" Background="Transparent" Foreground="White" FontWeight="Bold" BorderThickness="0" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" Height="44" CornerRadius="0" Click="NavBtn_Click">
                    <Grid><Rectangle x:Name="AboutInd" Fill="#FF66FFFF" Width="3" HorizontalAlignment="Left" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xEA3A;" FontWeight="Bold" Foreground="White" FontSize="14" Margin="12,0,8,0"/>
                        <TextBlock Text="About" VerticalAlignment="Center"/>
                    </StackPanel></Grid>
                </Button>
                <!-- Spacer (row 3 is star) — video fully visible -->
                <!-- Settings -->
                <Button Grid.Row="4" x:Name="SettingsBtn" Tag="settings" Background="Transparent" Foreground="White" FontWeight="Bold" BorderThickness="0" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" Height="44" CornerRadius="0" Click="NavBtn_Click">
                    <Grid><Rectangle x:Name="SettingsInd" Fill="#FF66FFFF" Width="3" HorizontalAlignment="Left" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE713;" FontWeight="Bold" Foreground="White" FontSize="14" Margin="12,0,8,0"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel></Grid>
                </Button>
            </Grid>
            <!-- Content area -->
            <Frame Grid.Column="1" x:Name="NavFrame"/>
        </Grid>
    </Grid>
</Window>
