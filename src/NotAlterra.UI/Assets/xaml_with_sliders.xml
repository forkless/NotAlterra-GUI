<Page x:Class="YourApp.UnderwaterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Microsoft.Graphics.Canvas.UI.Xaml">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main content with underwater overlay -->
        <Grid Grid.Row="0">
            <Image x:Name="BackgroundImage" 
                   Source="your-underwater-scene.jpg"
                   Stretch="UniformToFill"/>
            
            <controls:CanvasAnimatedControl x:Name="underwaterCanvas" 
                                            Grid.Row="0"
                                            Draw="OnDraw" 
                                            Update="OnUpdate"
                                            ClearColor="Transparent"/>
        </Grid>
        
        <!-- Control Panel - Agent-friendly sliders -->
        <StackPanel Grid.Row="1" 
                    Background="#CC000000" 
                    Padding="20,10">
            
            <TextBlock Text="🌊 Underwater Controls" 
                       Foreground="White" 
                       FontSize="16" 
                       Margin="0,0,0,10"/>
            
            <Slider x:Name="causticIntensity" 
                    Minimum="0" Maximum="100" Value="30"
                    Width="200" Margin="0,5"/>
            <TextBlock Text="Caustic Intensity" Foreground="White" FontSize="12"/>
            
            <Slider x:Name="warpAmount" 
                    Minimum="0" Maximum="50" Value="20"
                    Width="200" Margin="0,5"/>
            <TextBlock Text="Warp/Distortion" Foreground="White" FontSize="12"/>
            
            <Slider x:Name="particleCount" 
                    Minimum="0" Maximum="100" Value="60"
                    Width="200" Margin="0,5"/>
            <TextBlock Text="Particles" Foreground="White" FontSize="12"/>
            
            <Slider x:Name="bubbleSize" 
                    Minimum="5" Maximum="50" Value="20"
                    Width="200" Margin="0,5"/>
            <TextBlock Text="Bubble Size" Foreground="White" FontSize="12"/>
            
            <Slider x:Name="speed" 
                    Minimum="0" Maximum="200" Value="100"
                    Width="200" Margin="0,5"/>
            <TextBlock Text="Animation Speed" Foreground="White" FontSize="12"/>
            
            <Slider x:Name="warmth" 
                    Minimum="0" Maximum="100" Value="50"
                    Width="200" Margin="0,5"/>
            <TextBlock Text="Warmth (Golden vs Blue)" Foreground="White" FontSize="12"/>
            
            <CheckBox x:Name="showBubbles" 
                      Content="Show Bubbles" 
                      Foreground="White" 
                      IsChecked="True"
                      Margin="0,5"/>
        </StackPanel>
    </Grid>
</Page>